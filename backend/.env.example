APP_ENV=development
LOG_LEVEL=INFO

POSTGRES_DB=ubnd_reports
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/ubnd_reports
OPERATIONAL_STORAGE_DIR=./storage/operational_reports
REPORT_OUTPUT_DIR=./storage/generated_reports
DATASET_ROOT=../ubnd_report_dataset
ALLOWED_CORS_ORIGINS=http://localhost:5173

FPT_API_KEY=
FPT_BASE_URL=
FPT_EMBEDDING_API_KEY=
FPT_EMBEDDING_BASE_URL=

EMBEDDING_PROVIDER=fpt
EMBEDDING_MODEL=Vietnamese_Embedding
EMBEDDING_BATCH_SIZE=32
EMBEDDING_NORMALIZE=true
EMBEDDING_TIMEOUT_SECONDS=120
EMBEDDING_MAX_RETRIES=3
EMBEDDING_DIMENSION=

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=ubnd_knowledge_base
QDRANT_DISTANCE=COSINE
QDRANT_UPSERT_BATCH_SIZE=64
QDRANT_RECREATE_COLLECTION=false

KNOWLEDGE_BASE_STORAGE_DIR=./storage/knowledge_base
KNOWLEDGE_BASE_ORIGINAL_DIR=./storage/knowledge_base/originals
KNOWLEDGE_BASE_PROCESSED_DIR=./storage/knowledge_base/processed
KNOWLEDGE_BASE_FAILED_DIR=./storage/knowledge_base/failed
MAX_DOCUMENT_SIZE_MB=50

KNOWLEDGE_BASE_SEED_DIR=
KNOWLEDGE_BASE_SEED_MAPPING=
DUPLICATE_DOCUMENT_POLICY=skip
RUN_EXTERNAL_INTEGRATION_TESTS=false
RUN_LOCAL_INTEGRATION_TESTS=false
POSTGRES_TEST_DATABASE_URL=
QDRANT_TEST_URL=http://localhost:6333

RAG_CANDIDATE_TOP_K=20
RAG_FINAL_TOP_K=5
RAG_MAX_CONTEXT_TOKENS=6000
RAG_DEFAULT_DOCUMENT_STATUS=active
RAG_ENABLE_DENSE_SEARCH=true
RAG_ENABLE_LEXICAL_SEARCH=true
RAG_ENABLE_HYBRID_SEARCH=true
RAG_ENABLE_RERANKER=true
RAG_ENABLE_PARENT_EXPANSION=true
RAG_DENSE_WEIGHT=1.0
RAG_LEXICAL_WEIGHT=1.0
RAG_RRF_K=60
BM25_K1=1.5
BM25_B=0.75

RERANKER_PROVIDER=fpt
FPT_RERANKER_API_KEY=
FPT_RERANKER_BASE_URL=
RERANKER_MODEL=bge-reranker-v2-m3
RERANKER_BATCH_SIZE=16
RERANKER_TIMEOUT_SECONDS=120
RERANKER_MAX_RETRIES=3

LLM_PROVIDER=fpt
FPT_LLM_API_KEY=
FPT_LLM_BASE_URL=
LLM_MODEL=Llama-3.3-70B-Instruct
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=3
LLM_ENABLED=false

AGENT_MAX_STEPS=6
AGENT_ENABLE_PRODUCTION_ORCHESTRATION=false
